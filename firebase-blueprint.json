{
  "entities": {
    "userProfiles": {
      "title": "User Profile",
      "description": "User specific data like balance and settings",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "totalPoints": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "totalPoints"]
    },
    "operatorAccounts": {
      "title": "Operator Account",
      "description": "BharatGas account linked to the manager",
      "type": "object",
      "properties": {
        "mobile": { "type": "string" },
        "name": { "type": "string" },
        "model": { "type": "string" },
        "deviceId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Offline", "Sync Required"] },
        "ownerId": { "type": "string" },
        "whitelistCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["mobile", "name", "ownerId", "whitelistCode"]
    },
    "orders": {
      "title": "Order",
      "description": "Delivery order associated with an operator account",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "accountId": { "type": "string" },
        "customer": { "type": "string" },
        "mobile": { "type": "string" },
        "lpgId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "points": { "type": "number" },
        "completedAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["orderId", "accountId", "customer", "status", "ownerId"]
    },
    "transactions": {
      "title": "Transaction",
      "description": "Point usage history",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "amount": { "type": "number" },
        "reason": { "type": "string" },
        "account": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "amount", "reason", "ownerId"]
    }
  },
  "firestore": {
    "userProfiles/{userId}": {
      "schema": "userProfiles",
      "description": "User profile records"
    },
    "operatorAccounts/{accountId}": {
      "schema": "operatorAccounts",
      "description": "Managed BharatGas accounts"
    },
    "orders/{docId}": {
      "schema": "orders",
      "description": "Consolidated orders"
    },
    "transactions/{txId}": {
      "schema": "transactions",
      "description": "Point transaction logs"
    }
  }
}
